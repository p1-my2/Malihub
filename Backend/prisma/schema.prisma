generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model accounts {
  account_id   Int                   @id @default(autoincrement())
  user_id      Int
  account_name String                @db.VarChar(50)
  account_type accounts_account_type
  balance      Decimal               @default(0.00) @db.Decimal(14, 2)
  is_active    Boolean               @default(true)
  created_at   DateTime              @default(now()) @db.DateTime(0)
  users        users                 @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_user")
  transactions transactions[]

  @@index([user_id], map: "fk_account_user")
}

model budgets {
  budget_id       Int                 @id @default(autoincrement())
  user_id         Int
  category_id     Int
  budget_amount   Decimal             @db.Decimal(14, 2)
  period_type     budgets_period_type
  start_date      DateTime            @db.Date
  alert_threshold Decimal?            @db.Decimal(5, 2)
  categories      categories          @relation(fields: [category_id], references: [category_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_budget_category")
  users           users               @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_budget_user")

  @@index([category_id], map: "fk_budget_category")
  @@index([user_id], map: "fk_budget_user")
}

model categories {
  category_id   Int            @id @default(autoincrement())
  user_id       Int
  category_name String         @db.VarChar(50)
  icon          String?        @db.VarChar(50)
  is_default    Boolean        @default(false)
  budgets       budgets[]
  users         users          @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_category_user")
  transactions  transactions[]

  @@unique([user_id, category_name], map: "uq_user_category")
}

model financial_goals {
  goal_id        Int       @id @default(autoincrement())
  user_id        Int
  goal_name      String    @db.VarChar(50)
  target_amount  Decimal   @db.Decimal(14, 2)
  current_amount Decimal   @default(0.00) @db.Decimal(14, 2)
  deadline       DateTime? @db.Date
  users          users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_goal_user")

  @@index([user_id], map: "fk_goal_user")
}

model notifications {
  notification_id   Int                             @id @default(autoincrement())
  user_id           Int
  notification_type notifications_notification_type
  message           String                          @db.Text
  is_read           Boolean                         @default(false)
  created_at        DateTime                        @default(now()) @db.DateTime(0)
  users             users                           @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_guser")

  @@index([user_id], map: "fk_notification_guser")
}

model transactions {
  transaction_id   Int                           @id @default(autoincrement())
  account_id       Int
  category_id      Int
  amount           Decimal                       @db.Decimal(14, 2)
  transaction_type transactions_transaction_type
  description      String?                       @db.VarChar(150)
  transaction_date DateTime                      @default(dbgenerated("(curdate())")) @db.Date
  accounts         accounts                      @relation(fields: [account_id], references: [account_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_transaction_account")
  categories       categories                    @relation(fields: [category_id], references: [category_id], onUpdate: NoAction, map: "fk_transaction_category")

  @@index([account_id], map: "fk_transaction_account")
  @@index([category_id], map: "fk_transaction_category")
}

model users {
  user_id             Int               @id @default(autoincrement())
  first_name          String            @db.VarChar(50)
  last_name           String            @db.VarChar(50)
  email               String            @unique(map: "email") @db.VarChar(100)
  phone_number        String?           @db.VarChar(20)
  currency_preference String            @default("KES") @db.VarChar(3)
  password_hash       String            @db.VarChar(255)
  is_active           Boolean           @default(true)
  last_login_at       DateTime?         @db.DateTime(0)
  created_at          DateTime          @default(now()) @db.DateTime(0)
  updated_at          DateTime          @default(now()) @db.DateTime(0)
  accounts            accounts[]
  budgets             budgets[]
  categories          categories[]
  financial_goals     financial_goals[]
  notifications       notifications[]
}

enum notifications_notification_type {
  budget_exceeded
  goal_milestone
}

enum accounts_account_type {
  checking
  savings
  credit_card
  cash
}

enum budgets_period_type {
  weekly
  monthly
  yearly
}

enum transactions_transaction_type {
  debit
  credit
}
